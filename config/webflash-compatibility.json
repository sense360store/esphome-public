{
  "version": 1,
  "source_of_truth": "docs/webflash-contract.md",
  "filename_pattern": "Sense360-{config_string}-v{version}-{channel}.bin",
  "channels": ["stable", "preview", "beta"],
  "tokens": {
    "mounting": ["Ceiling"],
    "power": ["USB", "POE", "PWR"],
    "modules": [
      "AirIQ",
      "VentIQ",
      "RoomIQ",
      "FanRelay",
      "FanPWM",
      "FanDAC",
      "FanTRIAC",
      "LED"
    ]
  },
  "module_order": ["AirIQ_or_VentIQ", "FanDriver", "RoomIQ", "LED"],
  "module_order_groups": {
    "AirIQ_or_VentIQ": ["AirIQ", "VentIQ"],
    "FanDriver": ["FanRelay", "FanPWM", "FanDAC", "FanTRIAC"],
    "RoomIQ": ["RoomIQ"],
    "LED": ["LED"]
  },
  "forbidden_tokens": {
    "Bathroom": "VentIQ",
    "Comfort": "RoomIQ",
    "Presence": "RoomIQ",
    "Fan": "FanRelay / FanPWM / FanDAC / FanTRIAC",
    "BathroomAirIQ": "VentIQ",
    "AirIQBase": "AirIQ",
    "AirIQPro": "AirIQ",
    "AirIQProv": "AirIQ",
    "FanAnalog": "FanDAC"
  },
  "mutually_exclusive": [
    ["AirIQ", "VentIQ"]
  ],
  "conflicts": [
    {
      "a": "AirIQ",
      "b": "FanDAC",
      "reason": "Shared DAC bus contention (see docs/webflash-contract.md §5 rule 6)"
    }
  ],
  "max_one_of": {
    "fan_driver": ["FanRelay", "FanPWM", "FanDAC", "FanTRIAC"]
  }
}
