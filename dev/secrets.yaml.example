# ============================================================================
# SENSE360 DEV HARNESS — BENCH SECRETS TEMPLATE (placeholders only)
# ============================================================================
# Copy this file to dev/secrets.yaml — which is gitignored — and fill in real
# bench values there (or paste the keys into the Home Assistant ESPHome
# dashboard secrets editor). NEVER commit a real secrets.yaml.
#
# Every value below is an obviously-fake REPLACE_ME_ placeholder. None of
# them matches any default / test-lane credential on the release binary
# scanner's denylist (scripts/check_firmware_default_credentials.py), and
# they must stay that way.
# ============================================================================

# Bench WiFi network (packages/base/wifi.yaml).
wifi_ssid: "REPLACE_ME_WIFI_SSID"
wifi_password: "REPLACE_ME_WIFI_PASSWORD"

# Fallback access-point password (packages/base/wifi.yaml). A real
# credential: the AP + captive portal activates whenever the device cannot
# join WiFi. Use a unique, strong value per bench unit.
fallback_ap_password: "REPLACE_ME_FALLBACK_AP_PASSWORD"

# Home Assistant native-API encryption key (packages/base/api_encrypted.yaml).
# Must be 32 random bytes, base64-encoded. Generate per bench unit:
#     openssl rand -base64 32
api_encryption_key: "REPLACE_ME_GENERATE_WITH_openssl_rand_base64_32"

# OTA password (packages/base/ota.yaml) — required for every reflash after
# the first USB flash.
ota_password: "REPLACE_ME_OTA_PASSWORD"

# Web server auth on :80 (packages/base/logging.yaml).
web_username: "REPLACE_ME_WEB_USERNAME"
web_password: "REPLACE_ME_WEB_PASSWORD"
